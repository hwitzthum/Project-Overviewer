# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Environment ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# ─── Database ────────────────────────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino.log*

# ─── Build / Cache ───────────────────────────────────────────────────────────
.cache/
/dist/
build/
# public/dist/ is generated by `npm run build` (scripts/build-frontend.js) and
# must NOT be committed. The build script renames hashed bundles on every run;
# committing stale outputs causes Vercel packaging to ENOENT on deleted hashes.
public/dist/
.parcel-cache/
.vercel/

# ─── Testing ─────────────────────────────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
coverage/

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── IDE / Editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sublime-workspace

# ─── Temporary Files ─────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
*.orig

# ─── Python (venv artifacts) ─────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]

# ─── Security ────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
secrets/