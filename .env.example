# Project Overviewer Configuration
# Copy this to .env and fill in your values

# Admin account (created on first startup)
ADMIN_USER=admin
ADMIN_PASS=ChangeThisToASecurePassword!

# Server port (default: 3001)
PORT=3001

# Node environment (production enables Secure cookie flag)
NODE_ENV=development

# Canonical app origin used for same-origin checks and secure cookies
APP_ORIGIN=http://localhost:3001

# Reverse proxy trust. Use `false` locally, `1` behind a single trusted proxy.
TRUST_PROXY=false

# Allowed origin for CORS (if needed)
# ALLOWED_ORIGIN=https://yourdomain.com

# Turso Database (production - get from Turso dashboard)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# For local development, leave TURSO_DATABASE_URL unset to use file:projects.db

# Server bind address (default: localhost in dev, 0.0.0.0 in production)
# HOST=0.0.0.0

# Logging level: fatal, error, warn, info, debug, trace (default: info)
# LOG_LEVEL=info

# File path for security event logs (optional, logs to stdout if unset)
# SECURITY_LOG_PATH=./logs/security.log

# Session configuration (all values in milliseconds)
# SESSION_ABSOLUTE_TIMEOUT_MS=86400000    # 24 hours — max session lifetime
# SESSION_IDLE_TIMEOUT_MS=3600000         # 1 hour — idle timeout
# SESSION_TOKEN_BYTES=32                  # Token entropy (bytes)
# SESSION_TOUCH_INTERVAL_MS=300000        # 5 minutes — how often to refresh idle timer
