{
  "name": "project-overviewer",
  "version": "1.0.0",
  "description": "Professional project and task management app with SQLite database",
  "main": "server.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "node scripts/build-frontend.js",
    "prestart": "npm run build",
    "start": "node server.js",
    "predev": "npm run build",
    "dev": "node server.js",
    "pretest": "npm run build",
    "audit:deps": "npm audit --audit-level=high",
    "test": "node scripts/run-playwright.js test",
    "test:ui": "node scripts/run-playwright.js test --ui"
  },
  "keywords": [
    "project-management",
    "task-manager",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@libsql/client": "^0.15.14",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.27.4",
    "pino-pretty": "^13.1.3"
  },
  "overrides": {
    "node-domexception": "file:vendor/node-domexception"
  }
}
