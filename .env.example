# Project Overviewer Configuration
# Copy this to .env and fill in your values

# Admin account (created on first startup)
ADMIN_USER=admin
ADMIN_PASS=ChangeThisToASecurePassword!

# Server port (default: 3001)
PORT=3001

# Node environment (production enables Secure cookie flag)
NODE_ENV=development

# Canonical app origin used for same-origin checks and secure cookies
APP_ORIGIN=http://localhost:3001

# Reverse proxy trust. Use `false` locally, `1` behind a single trusted proxy.
TRUST_PROXY=false

# Allowed origin for CORS (if needed)
# ALLOWED_ORIGIN=https://yourdomain.com

# Turso Database (production - get from Turso dashboard)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# For local development, leave TURSO_DATABASE_URL unset to use file:projects.db
