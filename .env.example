# Project Overviewer Configuration
# Copy this to .env and fill in your values

# Admin account (created on first startup)
ADMIN_USER=admin
ADMIN_PASS=ChangeThisToASecurePassword!

# Server port (default: 3001)
PORT=3001

# Node environment (production enables Secure cookie flag)
NODE_ENV=development

# Allowed origin for CORS (if needed)
# ALLOWED_ORIGIN=https://yourdomain.com